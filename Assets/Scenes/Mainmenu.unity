  teamMembers:
  - name: "L\xEA Ph\u1EA1m Mi \u0110oan"
    role: "Nh\xF3m tr\u01B0\u1EDFng"
    contributions: "BattleSystem & Pokemon (V\xF2ng l\u1EB7p Turn-based, t\xEDnh
      EXP, Class). Debuff/Buff (Thu\u1EADt to\xE1n ch\u1EC9 s\u1ED1 & D\u1ECB th\u01B0\u1EDDng).\nAnimation
      \nQu\u1EA3n l\xFD m\xE3 ngu\u1ED3n (Github, Repository, merge)"
    avatar: {fileID: 460402656023440085, guid: cad0d1427a6b1854aaabf071dc030b25, type: 3}
  - name: "V\xF5 Th\u1ECB Minh \xC2n"
    role: "Giao di\u1EC7n UI/UX"
    contributions: "UI Battle (B\u1EADt t\u1EAFt icon tr\u1EA1ng th\xE1i, text, thanh
      m\xE1u/EXP). \nParty & Bag Screen (Qu\u1EA3n l\xFD 6 Pokemon, t\xFAi \u0111\u1ED3).
      \nMainmenu (Kh\u1EDFi \u0111\u1ED9ng, chuy\u1EC3n c\u1EA3nh). \nAsset (Qu\u1EA3n
      l\xFD asset). Thi\u1EBFt k\u1EBF Canvas Overlay, thu\u1EADt to\xE1n anchoredPosition"
    avatar: {fileID: -2967266019844855193, guid: 22dfa1b254778c14f8d7ec9b52a4b7c3, type: 3}
  - name: "Nguy\u1EC5n Trung Ki\xEAn"
    role: Systems & Audio Engineer
    contributions: "Gym & Move (K\u1ECBch b\u1EA3n Gym AI, kh\xF3a b\u1ECF ch\u1EA1y,),\nHeal
      (Logic),\n PokeCenter, ph\u1EE5c h\u1ED3i HP/PP/Status). \nMove(Chi\xEAu th\u1EE9c)\nMusic
      (SoundManager, nh\u1EA1c n\u1EC1n/SFX)."
    avatar: {fileID: 4366363395544893404, guid: 78143a69eefc2c6459a0f74827894c38, type: 3}
  - name: "Nguy\u1EC5n Ho\xE0ng Hi\u1EBFu Ngh\u0129a"
    role: Gameplay Mechanics Developer
    contributions: "Player (Di chuy\u1EC3n, va ch\u1EA1m hitbox map). \nStart & B\u1EAFt
      Pokemon (Ch\u1ECDn starter, to\xE1n h\u1ECDc t\u1EF7 l\u1EC7 b\u1EAFt).\nItem
      & H\u1EC7 (Logic d\xF9ng map, ma tr\u1EADn h\u1EC7 ng\u0169 h\xE0nh)"
    avatar: {fileID: -1299836240224833357, guid: 3d14845bc395c684797b691dd2b953d2, type: 3}
